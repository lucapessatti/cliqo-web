---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
import Footer from "../components/Footer.astro";

// Galería de diseños. Sustituye estos placeholders por capturas reales
// de vuestros proyectos cuando los tengáis.
const disenos = [
  { title: "Restaurante", tag: "Hostelería", desc: "Web con carta digital y reservas online integradas.", accent: "from-brand-500 to-brand-300" },
  { title: "Peluquería", tag: "Belleza", desc: "Reserva de cita automática y galería de trabajos.", accent: "from-brand-600 to-brand-400" },
  { title: "Clínica dental", tag: "Salud", desc: "Web corporativa enfocada en captar nuevos pacientes.", accent: "from-brand-400 to-brand-200" },
  { title: "Taller mecánico", tag: "Automoción", desc: "Presupuestos online y ficha de Google optimizada.", accent: "from-brand-500 to-brand-400" },
  { title: "Academia", tag: "Formación", desc: "Catálogo de cursos con inscripción directa.", accent: "from-brand-600 to-brand-300" },
  { title: "Tienda local", tag: "Comercio", desc: "Catálogo online con pedidos por WhatsApp.", accent: "from-brand-400 to-brand-300" },
];
---

<Layout title="Nuestros diseños — Cliqo">
  <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur-md">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
      <Logo />
      <a href="/" class="flex items-center gap-2 text-sm font-semibold text-slate-600 transition-colors hover:text-brand-600">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5M11 18l-6-6 6-6" />
        </svg>
        Volver al inicio
      </a>
    </div>
  </header>

  <main class="bg-white">
    <section class="bg-gradient-to-br from-brand-600 via-brand-500 to-brand-400 py-24">
      <div class="mx-auto max-w-7xl px-6 text-center">
        <span class="text-sm font-semibold uppercase tracking-wide text-white/70">Portfolio</span>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Nuestros diseños
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-white/85">
          Webs pensadas para comercios locales: rápidas, claras y diseñadas para
          convertir visitas en clientes.
        </p>
      </div>
    </section>

    <section class="py-24">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {
            disenos.map((d) => (
              <article class="flex flex-col overflow-hidden rounded-2xl border border-slate-200 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-900/5">
                <div class={`relative flex h-56 items-center justify-center bg-gradient-to-br ${d.accent}`}>
                  <span class="absolute left-4 top-4 rounded-full bg-white/20 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                    {d.tag}
                  </span>
                  <svg width="72" height="72" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                    <circle cx="16" cy="16" r="12" stroke="white" stroke-width="1.5" opacity="0.8" />
                    <circle cx="16" cy="16" r="6.5" stroke="white" stroke-width="1.5" opacity="0.9" />
                    <circle cx="16" cy="16" r="2.8" fill="white" />
                  </svg>
                </div>
                <div class="flex flex-1 flex-col p-7">
                  <h2 class="text-xl font-bold text-ink">{d.title}</h2>
                  <p class="mt-3 text-sm leading-relaxed text-slate-600">{d.desc}</p>
                </div>
              </article>
            ))
          }
        </div>

        <div class="mt-20 rounded-2xl bg-slate-50 px-8 py-14 text-center">
          <h2 class="text-2xl font-extrabold text-ink sm:text-3xl">¿Te gusta lo que ves?</h2>
          <p class="mx-auto mt-4 max-w-md text-lg leading-relaxed text-slate-600">
            Pídenos tu primer borrador gratis y en 24 horas lo tienes sobre la mesa.
          </p>
          <a
            href="/#contacto"
            class="mt-8 inline-block rounded-full bg-brand-600 px-8 py-4 text-base font-bold text-white shadow-lg shadow-brand-600/30 transition-transform hover:scale-105"
          >
            Quiero mi borrador gratis
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
