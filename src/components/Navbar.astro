---
const links = [
  { label: "Servicios", href: "/#servicios" },
  { label: "Cómo trabajamos", href: "/#proceso" },
  { label: "Proyectos", href: "/#proyectos" },
  { label: "Precios", href: "/#precios" },
  { label: "Contacto", href: "/#contacto" },
];
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-all duration-300">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="/" class="group flex items-center gap-3">
      <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-600 shadow-sm transition-transform group-hover:scale-105">
        <svg width="24" height="24" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <circle cx="16" cy="16" r="12" stroke="white" stroke-width="2" />
          <circle cx="16" cy="16" r="6.5" stroke="white" stroke-width="2" />
          <circle cx="16" cy="16" r="2.8" fill="white" />
        </svg>
      </span>
      <span class="leading-tight">
        <span id="logo-name" class="block text-lg font-extrabold tracking-tight text-white transition-colors">Cliqo</span>
        <span id="logo-sub" class="block text-[11px] font-medium text-white/60 transition-colors">Marketing local</span>
      </span>
    </a>

    <div class="nav-pill hidden items-center gap-1 rounded-full border px-2 py-1.5 backdrop-blur-md transition-colors lg:flex">
      {
        links.map((link) => (
          <a href={link.href} class="nav-link rounded-full px-4 py-2 text-sm font-medium transition-colors">
            {link.label}
          </a>
        ))
      }
    </div>

    <a href="/#contacto" data-contact-modal class="cta flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold shadow-sm transition-all hover:scale-105">
      Auditoría gratis
      <span class="cta-dot grid h-5 w-5 place-items-center rounded-full transition-colors">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </a>
  </nav>
</header>

<style>
  #site-header.scrolled {
    background: #ffffff;
    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.06), 0 8px 24px rgba(15, 23, 42, 0.06);
  }
  #site-header.scrolled #logo-name { color: #0f172a; }
  #site-header.scrolled #logo-sub { color: #64748b; }

  .nav-link { color: rgba(255, 255, 255, 0.9); }
  .nav-pill { background: rgba(255, 255, 255, 0.12); border-color: rgba(255, 255, 255, 0.25); }
  #site-header.scrolled .nav-link { color: #475569; }
  #site-header.scrolled .nav-link:hover { color: #059669; }
  #site-header.scrolled .nav-pill { background: #f1f5f9; border-color: #e2e8f0; }

  .cta { background: #ffffff; color: #0f172a; }
  .cta-dot { background: #059669; color: #ffffff; }
  #site-header.scrolled .cta { background: #059669; color: #ffffff; }
  #site-header.scrolled .cta .cta-dot { background: #ffffff; color: #059669; }
</style>

<script is:inline>
  (() => {
    const header = document.getElementById("site-header");
    const onScroll = () => header.classList.toggle("scrolled", window.scrollY > 40);
    onScroll();
    document.addEventListener("scroll", onScroll, { passive: true });
  })();
</script>
