---
const team = [
  {
    initial: "L",
    name: "Luca Pessatti",
    role: "Datos y estrategia",
    bio: "Convierte los datos en decisiones. Se encarga del SEO local, la analítica y los informes mensuales para que veas crecer tu negocio con números reales.",
    skills: ["SEO local", "Power BI", "Python", "Analítica"],
  },
  {
    initial: "J",
    name: "Jesús",
    role: "Desarrollo web",
    bio: "Construye webs rápidas, bonitas y a medida. Del diseño al código, se asegura de que tu web funcione perfecta en cualquier dispositivo.",
    skills: ["Desarrollo web", "JavaScript", "PHP", "Diseño"],
  },
];
---

<section id="nosotros" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Quiénes somos</span>
      <h2 class="mt-3 text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">
        Detrás de Cliqo, dos personas de Valencia
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        No somos una agencia enorme y sin cara. Somos Luca y Jesús, dos apasionados
        de la tecnología que ayudamos a los comercios de nuestra tierra a crecer online.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2">
      {
        team.map((m) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-8 transition-all hover:-translate-y-1 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-900/5">
            <div class="flex items-center gap-4">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-brand-600 text-2xl font-extrabold text-white">
                {m.initial}
              </div>
              <div>
                <h3 class="text-xl font-bold text-ink">{m.name}</h3>
                <p class="text-sm font-semibold text-brand-600">{m.role}</p>
              </div>
            </div>

            <p class="mt-5 text-sm leading-relaxed text-slate-600">{m.bio}</p>

            <div class="mt-5 flex flex-wrap gap-2">
              {m.skills.map((s) => (
                <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">{s}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-10 flex items-center gap-3 rounded-2xl bg-slate-50 px-6 py-5">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z" /><circle cx="12" cy="10" r="3" /></svg>
      <p class="text-sm text-slate-600">
        Estamos en <strong class="text-ink">Valencia</strong>. Trabajamos de cerca, cara a cara, con cada negocio — como debe ser.
      </p>
    </div>
  </div>
</section>
