---
// Elemento visual del hero: mockup de navegador con una web "entregada",
// más insignias flotantes de resultado. Refuerza qué hace Cliqo.
---

<div class="relative mx-auto hidden w-full max-w-md lg:block" aria-hidden="true">
  <div class="overflow-hidden rounded-2xl bg-white shadow-2xl shadow-brand-900/30 ring-1 ring-black/5">
    <div class="flex items-center gap-2 border-b border-slate-100 bg-slate-50 px-4 py-3">
      <span class="h-3 w-3 rounded-full bg-red-400"></span>
      <span class="h-3 w-3 rounded-full bg-amber-400"></span>
      <span class="h-3 w-3 rounded-full bg-green-400"></span>
      <span class="ml-3 flex-1 rounded-md bg-white px-3 py-1 text-xs text-slate-400 ring-1 ring-slate-100">tunegocio.es</span>
    </div>

    <div class="p-5">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="grid h-6 w-6 place-items-center rounded-md bg-brand-600">
            <svg width="14" height="14" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="12" stroke="white" stroke-width="3" />
              <circle cx="16" cy="16" r="3" fill="white" />
            </svg>
          </span>
          <span class="h-2 w-14 rounded-full bg-slate-200"></span>
        </div>
        <span class="h-5 w-16 rounded-full bg-brand-100"></span>
      </div>

      <div class="mt-6 space-y-2">
        <div class="h-4 w-3/4 rounded bg-slate-800"></div>
        <div class="h-4 w-1/2 rounded bg-brand-500"></div>
      </div>
      <div class="mt-3 space-y-1.5">
        <div class="h-2 w-full rounded bg-slate-200"></div>
        <div class="h-2 w-5/6 rounded bg-slate-200"></div>
      </div>
      <div class="mt-4 flex gap-2">
        <span class="h-7 w-24 rounded-lg bg-brand-600"></span>
        <span class="h-7 w-20 rounded-lg bg-slate-100 ring-1 ring-slate-200"></span>
      </div>

      <div class="mt-5 grid grid-cols-3 gap-2">
        <div class="rounded-lg bg-slate-50 p-2 ring-1 ring-slate-100">
          <div class="h-8 rounded bg-brand-100"></div>
          <div class="mt-1.5 h-1.5 w-3/4 rounded bg-slate-200"></div>
        </div>
        <div class="rounded-lg bg-slate-50 p-2 ring-1 ring-slate-100">
          <div class="h-8 rounded bg-brand-200"></div>
          <div class="mt-1.5 h-1.5 w-3/4 rounded bg-slate-200"></div>
        </div>
        <div class="rounded-lg bg-slate-50 p-2 ring-1 ring-slate-100">
          <div class="h-8 rounded bg-brand-300"></div>
          <div class="mt-1.5 h-1.5 w-3/4 rounded bg-slate-200"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute -left-6 top-10 flex items-center gap-2 rounded-xl bg-white px-3 py-2 shadow-lg ring-1 ring-black/5">
    <span class="grid h-7 w-7 place-items-center rounded-lg bg-green-100 text-green-600">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
    </span>
    <div class="leading-tight">
      <p class="text-xs font-bold text-ink">Entregado en 24h</p>
      <p class="text-[10px] text-slate-400">Borrador listo</p>
    </div>
  </div>

  <div class="absolute -bottom-5 right-2 flex items-center gap-2 rounded-xl bg-white px-3 py-2 shadow-lg ring-1 ring-black/5">
    <span class="grid h-7 w-7 place-items-center rounded-lg bg-brand-100 text-brand-600">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 7-7M14 5h7v7" /></svg>
    </span>
    <div class="leading-tight">
      <p class="text-xs font-bold text-ink">+38% visitas</p>
      <p class="text-[10px] text-slate-400">primer trimestre</p>
    </div>
  </div>
</div>
