---
// Carrusel "coverflow" 3D (adaptado del componente React/framer-motion a Astro
// con JS puro + transforms CSS). Reemplaza la antigua sección "Lo que hacemos".
const items = [
  {
    title: "Restaurante El Rincón",
    meta: "Hostelería · Reservas",
    description: "Web con carta digital y reservas online para un restaurante de barrio.",
    img: "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=700&q=80",  },
  {
    title: "Peluquería Nova",
    meta: "Belleza · Cita online",
    description: "Reserva de cita automática y galería de trabajos para un salón local.",
    img: "https://images.unsplash.com/photo-1560066984-138dadb4c035?auto=format&fit=crop&w=700&q=80",  },
  {
    title: "Tienda Aroma",
    meta: "Comercio · Tienda online",
    description: "Catálogo online con pedidos por WhatsApp para una tienda de moda.",
    img: "https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=700&q=80",  },
  {
    title: "Clínica Fisio+",
    meta: "Salud · Captación",
    description: "Web corporativa enfocada en captar nuevos pacientes cada mes.",
    img: "https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?auto=format&fit=crop&w=700&q=80",  },
  {
    title: "Café Central",
    meta: "Hostelería · Local",
    description: "Presencia en Google y web sencilla para una cafetería del centro.",
    img: "https://images.unsplash.com/photo-1554118811-1e0d58224f24?auto=format&fit=crop&w=700&q=80",  },
];
---

<section id="proyectos" class="relative overflow-hidden bg-neutral-950 py-24 text-white">
  <div id="rail-bg" class="pointer-events-none absolute inset-0 z-0 opacity-30">
    <img id="rail-bg-img" src={items[0].img} alt="" class="h-full w-full object-cover" style="filter:blur(70px) saturate(1.7)" />
    <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/70 to-neutral-950/40"></div>
  </div>

  <div class="relative z-10">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <span class="text-sm font-semibold uppercase tracking-wide text-emerald-400">Proyectos</span>
      <h2 class="mt-3 text-4xl font-extrabold tracking-tight sm:text-5xl">Trabajos que hablan por nosotros</h2>
      <p class="mt-4 text-lg text-neutral-400">Un vistazo a las webs que creamos para negocios locales.</p>
    </div>

    <div id="rail" class="mt-14 outline-none" tabindex="0" role="group" aria-roledescription="carrusel" aria-label="Proyectos de Cliqo">
      <div id="rail-stage" class="relative mx-auto flex h-[380px] w-full max-w-6xl items-center justify-center select-none" style="perspective:1200px">
        {
          items.map((it) => (
            <div
              class="rail-card absolute aspect-square w-[240px] overflow-hidden rounded-3xl border-t border-white/20 bg-neutral-900 shadow-2xl md:w-[300px]"
              style="transform-style:preserve-3d;will-change:transform,opacity,filter"
              data-title={it.title}
              data-meta={it.meta}
              data-desc={it.description}
            >
              <img src={it.img} alt={it.title} loading="lazy" class="pointer-events-none h-full w-full object-cover" />
              <div class="pointer-events-none absolute inset-0 rounded-3xl bg-gradient-to-b from-white/10 to-transparent"></div>
            </div>
          ))
        }
      </div>

      <div class="mx-auto mt-10 flex max-w-4xl flex-col items-center gap-6 px-6 md:flex-row md:justify-between">
        <div class="min-h-[6rem] text-center md:text-left">
          <span id="rail-meta" class="text-xs font-semibold uppercase tracking-wider text-emerald-400"></span>
          <h3 id="rail-title" class="mt-1 text-2xl font-bold md:text-3xl"></h3>
          <p id="rail-desc" class="mt-1 max-w-md text-sm text-neutral-400"></p>
        </div>

        <div class="flex items-center gap-1 rounded-full bg-neutral-900/80 p-1 ring-1 ring-white/10 backdrop-blur-md">
          <button id="rail-prev" class="rounded-full p-3 text-neutral-400 transition hover:bg-white/10 hover:text-white active:scale-95" aria-label="Anterior">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6" /></svg>
          </button>
          <span id="rail-count" class="min-w-[46px] text-center font-mono text-xs text-neutral-500"></span>
          <button id="rail-next" class="rounded-full p-3 text-neutral-400 transition hover:bg-white/10 hover:text-white active:scale-95" aria-label="Siguiente">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .rail-card {
    cursor: pointer;
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.55s ease, filter 0.55s ease;
  }
  #rail-bg-img { transition: opacity 0.6s ease; }
  @media (prefers-reduced-motion: reduce) {
    .rail-card { transition: none; }
  }
</style>

<script>
  const rail = document.getElementById("rail");
  if (rail) {
    const stage = document.getElementById("rail-stage");
    const cards = Array.from(document.querySelectorAll(".rail-card"));
    const count = cards.length;
    const metaEl = document.getElementById("rail-meta");
    const titleEl = document.getElementById("rail-title");
    const descEl = document.getElementById("rail-desc");
    const countEl = document.getElementById("rail-count");
    const bgImg = document.getElementById("rail-bg-img");

    let active = 0;
    let step = 320;
    const computeStep = () => { step = window.innerWidth < 768 ? 200 : 320; };

    const signedOffset = (i) => {
      let raw = ((i - active) % count + count) % count;
      if (raw > count / 2) raw -= count;
      return raw;
    };

    const render = () => {
      cards.forEach((card, i) => {
        const offset = signedOffset(i);
        const dist = Math.abs(offset);
        if (dist > 2) {
          card.style.opacity = "0";
          card.style.pointerEvents = "none";
          card.style.zIndex = "0";
          return;
        }
        const isCenter = offset === 0;
        const x = offset * step;
        const z = -dist * 180;
        const scale = isCenter ? 1 : 0.85;
        const rotateY = offset * -18;
        card.style.transform = `translateX(${x}px) translateZ(${z}px) rotateY(${rotateY}deg) scale(${scale})`;
        card.style.opacity = String(isCenter ? 1 : Math.max(0.15, 1 - dist * 0.45));
        card.style.filter = `blur(${isCenter ? 0 : dist * 4}px) brightness(${isCenter ? 1 : 0.55})`;
        card.style.zIndex = String(isCenter ? 20 : 10 - dist);
        card.style.pointerEvents = "auto";
      });

      const c = cards[active];
      metaEl.textContent = c.dataset.title ? c.dataset.meta : "";
      titleEl.textContent = c.dataset.title || "";
      descEl.textContent = c.dataset.desc || "";
      countEl.textContent = `${active + 1} / ${count}`;
      if (bgImg.getAttribute("src") !== c.querySelector("img").src) {
        bgImg.src = c.querySelector("img").src;
      }
    };

    const go = (delta) => { active = ((active + delta) % count + count) % count; render(); };

    document.getElementById("rail-prev").addEventListener("click", () => go(-1));
    document.getElementById("rail-next").addEventListener("click", () => go(1));
    cards.forEach((card, i) => card.addEventListener("click", () => {
      const off = signedOffset(i);
      if (off !== 0) go(off);
    }));

    rail.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") go(-1);
      if (e.key === "ArrowRight") go(1);
    });

    let lastWheel = 0;
    rail.addEventListener("wheel", (e) => {
      if (Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return; // solo scroll horizontal, no secuestra la página
      const now = Date.now();
      if (now - lastWheel < 450) return;
      if (Math.abs(e.deltaX) > 20) { go(e.deltaX > 0 ? 1 : -1); lastWheel = now; }
    }, { passive: true });

    let startX = null;
    stage.addEventListener("pointerdown", (e) => { startX = e.clientX; });
    window.addEventListener("pointerup", (e) => {
      if (startX === null) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 60) go(dx < 0 ? 1 : -1);
      startX = null;
    });

    computeStep();
    window.addEventListener("resize", () => { computeStep(); render(); });
    render();
  }
</script>
