---
const servicios = [
  {
    title: "SEO local",
    desc: "Hacemos que aparezcas el primero cuando alguien busca tu servicio en Valencia. Optimizamos tu ficha y posicionamos tu negocio en Google.",
    tag: "El más demandado",
    icon: "search",
  },
  {
    title: "Diseño web profesional",
    desc: "Una web rápida, bonita y pensada para convertir visitas en clientes. Lista en 2 semanas, con hosting y mantenimiento incluidos.",
    tag: "Servicio estrella",
    icon: "layout",
  },
  {
    title: "Digitalización y analítica",
    desc: "Dashboards con Power BI para que veas tus ventas, tráfico y resultados en datos reales. Decisiones con cabeza, no a ciegas.",
    tag: "Te diferencia",
    icon: "chart",
  },
  {
    title: "Publicidad y reseñas",
    desc: "Campañas en Google Ads y gestión de reseñas para que ganes visibilidad y confianza desde el primer mes.",
    tag: "Resultados rápidos",
    icon: "megaphone",
  },
];

const icons: Record<string, string> = {
  search: "M11 19a8 8 0 1 1 0-16 8 8 0 0 1 0 16ZM21 21l-4.3-4.3",
  layout: "M3 3h18v18H3zM3 9h18M9 21V9",
  chart: "M3 3v18h18M7 16V9M12 16V6M17 16v-4",
  megaphone: "M3 11v2a1 1 0 0 0 1 1h2l5 4V6L6 10H4a1 1 0 0 0-1 1ZM15 8a4 4 0 0 1 0 8",
};
---

<section id="servicios" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Servicios</span>
      <h2 class="mt-3 text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">
        Todo lo que tu negocio necesita para vender más online
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Nos encargamos de la parte digital para que tú te dediques a lo que mejor
        sabes hacer: llevar tu negocio.
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        servicios.map((s) => (
          <article class="group rounded-2xl border border-slate-200 bg-white p-7 transition-all hover:-translate-y-1 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-900/5">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 transition-colors group-hover:bg-brand-600 group-hover:text-white">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={icons[s.icon]} />
              </svg>
            </span>
            <span class="mt-5 inline-block rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">
              {s.tag}
            </span>
            <h3 class="mt-3 text-xl font-bold text-ink">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{s.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
