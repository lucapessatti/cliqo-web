---
import PricingCard from "./PricingCard.astro";

const planes = [
  {
    title: "Presencia básica",
    tagline: "Para empezar a existir online",
    overview:
      "Landing page de 1 página, ficha de Google My Business y dominio con hosting el primer año.",
    price: "299€",
    period: "pago único",
    img: "https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=800&q=80",
    featured: false,
  },
  {
    title: "Crecimiento",
    tagline: "Lo que la mayoría de comercios necesita",
    overview:
      "Web completa (hasta 5 páginas), SEO local mensual, informe de resultados y soporte prioritario.",
    price: "149€",
    period: "/mes · sin permanencia",
    img: "https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?auto=format&fit=crop&w=800&q=80",
    featured: true,
  },
  {
    title: "Digitalización completa",
    tagline: "Para negocios que van a por todas",
    overview:
      "Todo lo de Crecimiento más dashboard con Power BI, gestión de redes sociales y campañas en Google Ads.",
    price: "299€",
    period: "/mes",
    img: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80",
    featured: false,
  },
];
---

<section id="precios" class="bg-slate-50 py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Precios</span>
      <h2 class="mt-3 text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">
        Planes claros, sin letra pequeña
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Precios pensados para comercios locales. Sin permanencia y sin sorpresas.
      </p>
    </div>

    <div class="mx-auto mt-14 grid max-w-6xl gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {planes.map((p) => <PricingCard {...p} />)}
    </div>

    <p class="mt-8 text-center text-sm text-slate-500">
      ¿No sabes cuál encaja contigo? Pídenos tu <strong class="text-ink">auditoría gratis</strong> y te lo decimos.
    </p>
  </div>
</section>
