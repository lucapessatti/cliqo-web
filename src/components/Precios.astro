---
const planes = [
  {
    name: "Presencia básica",
    price: "299€",
    period: "pago único",
    desc: "Para empezar a existir en internet.",
    features: ["Landing page de 1 página", "Ficha de Google My Business", "Dominio + hosting 1 año"],
    featured: false,
  },
  {
    name: "Crecimiento",
    price: "149€",
    period: "/mes · sin permanencia",
    desc: "Lo que la mayoría de comercios necesita.",
    features: ["Web completa (hasta 5 páginas)", "SEO local mensual", "Informe mensual de resultados", "Soporte prioritario"],
    featured: true,
  },
  {
    name: "Digitalización completa",
    price: "299€",
    period: "/mes",
    desc: "Para negocios que quieren ir a por todas.",
    features: ["Todo lo del plan Crecimiento", "Dashboard con Power BI", "Gestión de redes sociales", "Campañas en Google Ads"],
    featured: false,
  },
];
---

<section id="precios" class="bg-slate-50 py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Precios</span>
      <h2 class="mt-3 text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">
        Planes claros, sin letra pequeña
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Precios pensados para comercios locales. Sin permanencia y sin sorpresas.
      </p>
    </div>

    <div class="mx-auto mt-14 grid max-w-5xl gap-7 lg:grid-cols-3">
      {
        planes.map((p) => (
          <article
            class={`relative flex flex-col rounded-2xl bg-white p-8 ${p.featured ? "ring-2 ring-brand-600 shadow-xl shadow-brand-900/10" : "border border-slate-200"}`}
          >
            {p.featured && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-600 px-4 py-1 text-xs font-semibold text-white">
                Recomendado
              </span>
            )}
            <h3 class="text-lg font-bold text-ink">{p.name}</h3>
            <p class="mt-1 text-sm text-slate-500">{p.desc}</p>
            <div class="mt-5 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-ink">{p.price}</span>
              <span class="text-sm text-slate-400">{p.period}</span>
            </div>
            <ul class="mt-6 flex-1 space-y-3">
              {p.features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-slate-700">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href="#contacto"
              class={`mt-8 rounded-xl px-5 py-3.5 text-center text-sm font-semibold transition-colors ${p.featured ? "bg-brand-600 text-white hover:bg-brand-700" : "border border-slate-300 text-ink hover:border-brand-600 hover:bg-brand-50"}`}
            >
              Empezar ahora
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
