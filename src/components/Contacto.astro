---
const contactos = [
  { label: "Email", value: "hola@cliqo.es", icon: "M3 7l9 6 9-6M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2Z" },
  { label: "Teléfono", value: "6XX XXX XXX", icon: "M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.7a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.4-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.7.7a2 2 0 0 1 1.7 2Z" },
  { label: "Zona", value: "Valencia", icon: "M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0ZM12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" },
];
---

<section id="contacto" class="bg-gradient-to-br from-brand-600 via-brand-500 to-brand-400 py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <span class="text-sm font-semibold uppercase tracking-wide text-white/70">Contacto</span>
        <h2 class="mt-3 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Pide tu auditoría gratis
        </h2>
        <p class="mt-4 max-w-md text-lg text-white/85">
          Cuéntanos sobre tu negocio y te diremos exactamente cómo hacer que más
          clientes te encuentren. Sin coste ni compromiso.
        </p>

        <ul class="mt-8 space-y-4">
          {
            contactos.map((c) => (
              <li class="flex items-center gap-3 text-white">
                <span class="grid h-10 w-10 place-items-center rounded-xl bg-white/15">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={c.icon} />
                  </svg>
                </span>
                <span>
                  <span class="block text-xs text-white/60">{c.label}</span>
                  <span class="block font-semibold">{c.value}</span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <form
        class="rounded-2xl bg-white p-8 shadow-xl"
        action="https://formsubmit.co/hola@cliqo.es"
        method="POST"
      >
        <div class="space-y-4">
          <div>
            <label for="nombre" class="block text-sm font-medium text-ink">Nombre</label>
            <input id="nombre" name="nombre" type="text" required
              class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition-colors focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
          </div>
          <div>
            <label for="negocio" class="block text-sm font-medium text-ink">Tu negocio</label>
            <input id="negocio" name="negocio" type="text" required
              class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition-colors focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-ink">Email</label>
            <input id="email" name="email" type="email" required
              class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition-colors focus:border-brand-600 focus:ring-2 focus:ring-brand-100" />
          </div>
          <div>
            <label for="mensaje" class="block text-sm font-medium text-ink">¿Qué necesitas?</label>
            <textarea id="mensaje" name="mensaje" rows="3"
              class="mt-1.5 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition-colors focus:border-brand-600 focus:ring-2 focus:ring-brand-100"></textarea>
          </div>
          <button type="submit"
            class="w-full rounded-xl bg-brand-600 px-5 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-brand-700">
            Enviar y pedir auditoría
          </button>
          <p class="text-center text-xs text-slate-400">Te respondemos en menos de 24 horas.</p>
        </div>
      </form>
    </div>
  </div>
</section>
