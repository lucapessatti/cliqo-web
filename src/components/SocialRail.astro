---
const socials = [
  {
    label: "LinkedIn",
    href: "#",
    path: "M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm6 0h3.8v1.7h.05c.53-1 1.83-2.05 3.76-2.05C20.6 8.65 22 10.6 22 14v7h-4v-6.2c0-1.5-.03-3.4-2.07-3.4-2.07 0-2.39 1.6-2.39 3.3V21H9V9Z",
  },
  {
    label: "Facebook",
    href: "#",
    path: "M13.5 22v-8h2.7l.4-3.1h-3.1V8.9c0-.9.25-1.5 1.55-1.5h1.65V4.6c-.8-.1-1.6-.15-2.4-.15-2.4 0-4.05 1.46-4.05 4.16v2.29H7.5V14h2.75v8h3.25Z",
  },
  {
    label: "X",
    href: "#",
    path: "M17.5 3h3l-6.55 7.5L21.5 21h-5.9l-4.2-5.5L6.5 21h-3l7-8L2.5 3h6l3.8 5 5.2-5Zm-1.05 16h1.65L7.6 4.65H5.85L16.45 19Z",
  },
];
---

<div class="absolute right-6 top-1/2 z-20 hidden -translate-y-1/2 flex-col gap-3 lg:flex">
  {
    socials.map((s) => (
      <a
        href={s.href}
        aria-label={s.label}
        class="grid h-11 w-11 place-items-center rounded-full bg-white/85 text-brand-600 shadow-sm backdrop-blur-sm transition-transform hover:scale-110 hover:bg-white"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d={s.path} />
        </svg>
      </a>
    ))
  }
</div>
