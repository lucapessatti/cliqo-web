---
const items = [
  "SEO LOCAL",
  "DISEÑO WEB",
  "GOOGLE MY BUSINESS",
  "ANALÍTICA CON POWER BI",
  "PUBLICIDAD EN GOOGLE",
  "GESTIÓN DE RESEÑAS",
];
const loop = [...items, ...items];
---

<div class="absolute inset-x-0 bottom-0 z-20 border-t border-white/20 bg-white/10 py-3 backdrop-blur-sm">
  <div class="flex w-max animate-marquee items-center gap-3 whitespace-nowrap">
    {
      loop.map((item) => (
        <span class="flex items-center gap-3 text-xs font-semibold tracking-wide text-white/90">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#ffffff" aria-hidden="true">
            <path d="M13 2 4 14h6l-1 8 9-12h-6l1-8Z" />
          </svg>
          {item}
        </span>
      ))
    }
  </div>
</div>
