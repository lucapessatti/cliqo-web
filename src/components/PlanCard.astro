---
const features = [
  { label: "SEO local en Google", value: "Incluido" },
  { label: "Web profesional", value: "Incluido" },
  { label: "Informe mensual", value: "Cada mes" },
];
---

<div class="w-full max-w-sm rounded-2xl bg-white/95 p-6 shadow-xl shadow-brand-900/10 backdrop-blur-sm ring-1 ring-white/40">
  <div class="flex items-start justify-between">
    <span class="grid h-9 w-9 place-items-center rounded-lg bg-brand-50 text-brand-600">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M21 16V8a2 2 0 0 0-1-1.7l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.7l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
    <div class="flex -space-x-2">
      <span class="grid h-7 w-7 place-items-center rounded-full bg-brand-200 text-xs font-bold text-brand-800 ring-2 ring-white">M</span>
      <span class="grid h-7 w-7 place-items-center rounded-full bg-brand-400 text-xs font-bold text-white ring-2 ring-white">J</span>
      <span class="grid h-7 w-7 place-items-center rounded-full bg-brand-600 text-xs font-bold text-white ring-2 ring-white">+</span>
    </div>
  </div>

  <h2 class="mt-4 text-xl font-bold text-ink">Plan Crecimiento</h2>
  <p class="mt-1 text-sm text-slate-500">Todo lo que tu negocio necesita para destacar online.</p>

  <dl class="mt-5 space-y-3 border-t border-slate-100 pt-4">
    {
      features.map((f) => (
        <div class="flex items-center justify-between text-sm">
          <dt class="flex items-center gap-2 text-slate-600">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {f.label}
          </dt>
          <dd class="font-medium text-slate-400">{f.value}</dd>
        </div>
      ))
    }
  </dl>

  <div class="mt-5 flex items-baseline gap-1">
    <span class="text-3xl font-extrabold text-ink">149€</span>
    <span class="text-sm text-slate-400">/mes · sin permanencia</span>
  </div>

  <a
    href="#contacto"
    class="mt-4 flex items-center justify-between rounded-xl border border-slate-200 px-5 py-3.5 text-sm font-semibold text-ink transition-colors hover:border-brand-600 hover:bg-brand-50"
  >
    Empezar ahora
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</div>
