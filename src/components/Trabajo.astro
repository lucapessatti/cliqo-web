---
// Sustituye a "Casos": muestra el tipo de trabajo y entregables de Cliqo,
// en lugar de casos de clientes reales (que todavía no hay).
const trabajos = [
  {
    title: "Webs que convierten",
    desc: "Landing pages y webs corporativas rápidas, modernas y optimizadas para que la visita acabe llamándote o reservando.",
    bullets: ["Diseño a medida", "Adaptada a móvil", "Lista en 2 semanas"],
    img: "https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?auto=format&fit=crop&w=800&q=80",
  },
  {
    title: "Fichas de Google optimizadas",
    desc: "Configuramos y optimizamos tu Google My Business para que aparezcas en el mapa cuando buscan tu servicio en Valencia.",
    bullets: ["Más visibilidad local", "Gestión de reseñas", "Fotos y horarios"],
    img: "https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&w=800&q=80",
  },
  {
    title: "Dashboards de resultados",
    desc: "Paneles con Power BI donde ves de un vistazo cómo evoluciona tu negocio: visitas, llamadas, ventas y retorno real.",
    bullets: ["Datos en tiempo real", "Informe mensual", "Decisiones con datos"],
    img: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80",
  },
];
---

<section id="trabajo" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Lo que hacemos</span>
      <h2 class="mt-3 text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">
        Trabajo real, resultados que se ven
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Esto es lo que ponemos en marcha para cada negocio que confía en Cliqo.
      </p>
    </div>

    <div class="mt-14 grid gap-7 lg:grid-cols-3">
      {
        trabajos.map((t) => (
          <article class="overflow-hidden rounded-2xl border border-slate-200 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-brand-900/5">
            <div class="relative h-48 overflow-hidden">
              <img
                src={t.img}
                alt={t.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-900/30 to-transparent"></div>
            </div>
            <div class="p-7">
              <h3 class="text-xl font-bold text-ink">{t.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{t.desc}</p>
              <ul class="mt-4 space-y-2">
                {t.bullets.map((b) => (
                  <li class="flex items-center gap-2 text-sm text-slate-700">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-14 flex justify-center">
      <a
        href="/disenos"
        class="group inline-flex items-center gap-3 rounded-full bg-brand-600 px-8 py-4 text-base font-bold text-white shadow-lg shadow-brand-600/30 transition-all hover:scale-105 hover:bg-brand-700 hover:shadow-xl hover:shadow-brand-600/40"
      >
        Ver todos nuestros diseños
        <span class="grid h-6 w-6 place-items-center rounded-full bg-white/20 transition-transform group-hover:translate-x-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>
