---
interface Props {
  light?: boolean;
}
const { light = false } = Astro.props;
const text = light ? "text-white" : "text-ink";
const sub = light ? "text-white/60" : "text-slate-500";
---

<a href="/" class="flex items-center gap-3 group">
  <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-600 shadow-sm transition-transform group-hover:scale-105">
    <svg width="24" height="24" viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <circle cx="16" cy="16" r="12" stroke="white" stroke-width="2" />
      <circle cx="16" cy="16" r="6.5" stroke="white" stroke-width="2" />
      <circle cx="16" cy="16" r="2.8" fill="white" />
    </svg>
  </span>
  <span class="leading-tight">
    <span class={`block text-lg font-extrabold tracking-tight ${text}`}>Cliqo</span>
    <span class={`block text-[11px] font-medium ${sub}`}>Marketing local</span>
  </span>
</a>
